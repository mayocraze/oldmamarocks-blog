---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CategorySidebar from '../../components/CategorySidebar.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES } from '../../categories';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog'))
	.filter((p) => p.id !== 'tags-reference')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Category and year/month from URL (for initial active state; filtering is client-side for static)
const categorySlug = Astro.url.searchParams.get('category');
const yearSlug = Astro.url.searchParams.get('year');
const monthSlug = Astro.url.searchParams.get('month');

const tagToCategory = new Map<string, string>();
CATEGORIES.forEach((cat) => {
	const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
	cat.tags.forEach((tag) => tagToCategory.set(tag.toLowerCase(), slug));
});

// For static build, we always pass all posts; client script filters by ?category=
function getPostCategories(post: (typeof allPosts)[0]): string[] {
	const tags = (post.data.tags ?? []).map((t: string) => t.toLowerCase());
	const cats = new Set<string>();
	tags.forEach((tag) => {
		const cat = tagToCategory.get(tag);
		if (cat) cats.add(cat);
	});
	return Array.from(cats);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen">
		<Header />
		<div class="flex flex-col lg:flex-row lg:items-start w-full max-w-content mx-auto px-4 sm:px-6 lg:px-0 lg:gap-0">
			<div class="w-full lg:w-[85%] flex-shrink-0">
				<main class="flex-1 min-w-0 w-full py-8 px-0 pb-16 sm:py-8 sm:px-0 md:py-16 lg:py-16 lg:pr-6 lg:pl-[6.75rem]">
					<ul class="grid grid-cols-1 md:grid-cols-2 gap-10 sm:gap-12 md:gap-14 lg:gap-[5.5rem] list-none m-0 p-0 text-left w-full">
						{allPosts.map((post) => (
							<li
								class="post-card w-full"
								data-categories={getPostCategories(post).join(',')}
								data-year={post.data.pubDate.getFullYear()}
								data-month={(post.data.pubDate.getMonth() + 1).toString().padStart(2, '0')}
							>
								<a href={`/blog/${post.id}/`} class="group block no-underline hover:no-underline text-inherit">
									<div class="aspect-video overflow-hidden rounded-md">
										{post.data.heroImage ? (
											<Image width={1200} height={675} src={post.data.heroImage} alt="" class="w-full h-full object-cover block" />
										) : (
											<div class="w-full h-full bg-gray-200" />
										)}
									</div>
									<div class="flex flex-col gap-3.5 mt-5 text-left">
										<h2 class="font-semibold tracking-tight text-gray-900 text-xl sm:text-2xl md:text-3xl leading-snug m-0 group-hover:text-[#E8B7A9] transition-colors">
											{post.data.title}
										</h2>
										<p class="text-base lg:text-lg font-normal italic tracking-tight text-gray-500 m-0">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="post-snippet text-[0.9375rem] sm:text-base font-normal leading-relaxed text-gray-500 m-0 line-clamp-3 sm:line-clamp-4">
											{post.data.description}
										</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				</main>
			</div>
			<CategorySidebar
				posts={allPosts}
				activeCategory={categorySlug ?? undefined}
				activeYear={yearSlug ?? undefined}
				activeMonth={monthSlug ?? undefined}
			/>
			<script>
				// Client-side filtering for static build (category + year/month)
				function applyFilters() {
					const params = new URLSearchParams(location.search);
					const cat = params.get('category');
					const year = params.get('year');
					const month = params.get('month');
					const cards = document.querySelectorAll('.post-card');
					cards.forEach((card) => {
						let show = true;
						if (cat) {
							const cats = (card.getAttribute('data-categories') || '').split(',');
							show = cats.includes(cat);
						}
						if (show && year) {
							show = card.getAttribute('data-year') === year;
							if (show && month) show = card.getAttribute('data-month') === month;
						}
						(card as HTMLElement).style.display = show ? '' : 'none';
					});
					// Update active state on category links
					document.querySelectorAll('.category-link').forEach((link) => {
						link.classList.remove('text-gray-900', 'font-medium');
						const href = link.getAttribute('href') || '';
						const linkCat = href.includes('category=') ? new URL(href, location.origin).searchParams.get('category') : null;
						if ((!cat && !linkCat) || (cat && linkCat === cat)) {
							link.classList.add('text-gray-900', 'font-medium');
						}
					});
					// Update active state on archive links
					document.querySelectorAll('.archive-link').forEach((link) => {
						link.classList.remove('text-gray-900', 'font-medium');
						const href = link.getAttribute('href') || '';
						const url = new URL(href, location.origin);
						const linkYear = url.searchParams.get('year');
						const linkMonth = url.searchParams.get('month');
						if (linkYear === year && ((!month && !linkMonth) || (month && linkMonth === month))) {
							link.classList.add('text-gray-900', 'font-medium');
						}
					});
				}
				document.addEventListener('DOMContentLoaded', applyFilters);
				window.addEventListener('popstate', applyFilters);
				document.addEventListener('click', (e) => {
					const link = (e.target as HTMLElement).closest('a[href^="/blog"]');
					if (link && (link.classList.contains('category-link') || link.classList.contains('archive-link'))) {
						e.preventDefault();
						const url = new URL(link.getAttribute('href')!, location.origin);
						history.pushState({}, '', url.pathname + url.search);
						applyFilters();
					}
				});
			</script>
		</div>
		<Footer />
	</body>
</html>
