---
import { CATEGORIES } from '../categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
	activeCategory?: string;
	activeYear?: string;
	activeMonth?: string;
}

const { posts, activeCategory, activeYear, activeMonth } = Astro.props;

// Build tag -> category map
const tagToCategory = new Map<string, string>();
CATEGORIES.forEach((cat) => {
	const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
	cat.tags.forEach((tag) => tagToCategory.set(tag.toLowerCase(), slug));
});

// Count posts per category
const categoryCounts = new Map<string, number>();
CATEGORIES.forEach((cat) => {
	const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
	categoryCounts.set(slug, 0);
});

posts.forEach((post) => {
	const postTags = (post.data.tags ?? []).map((t: string) => t.toLowerCase());
	const foundCats = new Set<string>();
	postTags.forEach((tag) => {
		const cat = tagToCategory.get(tag);
		if (cat) foundCats.add(cat);
	});
	foundCats.forEach((cat) => categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1));
});

// Group posts by year and month
const yearMonthCounts = new Map<string, Map<string, number>>();
posts.forEach((post) => {
	const d = post.data.pubDate;
	const year = d.getFullYear().toString();
	const month = (d.getMonth() + 1).toString().padStart(2, '0');
	if (!yearMonthCounts.has(year)) yearMonthCounts.set(year, new Map());
	const months = yearMonthCounts.get(year)!;
	months.set(month, (months.get(month) ?? 0) + 1);
});
const MONTH_NAMES = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const years = Array.from(yearMonthCounts.keys()).sort((a, b) => parseInt(b) - parseInt(a));
---

<aside class="category-sidebar">
	<h3 class="sidebar-title">Categories</h3>
	<nav class="category-list">
		<a
			href="/blog"
			class:list={['category-link', { active: !activeCategory }]}
		>
			All
		</a>
		{CATEGORIES.map((cat) => {
			const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
			const count = categoryCounts.get(slug) ?? 0;
			return (
				<a
					href={`/blog?category=${encodeURIComponent(slug)}`}
					class:list={['category-link', { active: activeCategory === slug }]}
				>
					<span class="category-name">{cat.name}</span>
					{count > 0 && <span class="category-count">({count})</span>}
				</a>
			);
		})}
	</nav>
	<div class="year-month-section">
		<p class="sidebar-label">By Year & Month</p>
		<nav class="year-month-nav">
			{years.map((year) => {
				const months = yearMonthCounts.get(year)!;
				const yearTotal = Array.from(months.values()).reduce((a, b) => a + b, 0);
				return (
					<div class="year-group">
						<a
							href={`/blog?year=${year}`}
							class:list={['archive-link', 'year-link', { active: activeYear === year && !activeMonth }]}
							data-year={year}
						>
							{year} ({yearTotal})
						</a>
						<div class="months">
							{Array.from(months.entries())
								.sort(([a], [b]) => parseInt(b) - parseInt(a))
								.map(([month, count]) => (
									<a
										href={`/blog?year=${year}&month=${month}`}
										class:list={['archive-link', 'month-link', { active: activeYear === year && activeMonth === month }]}
										data-year={year}
										data-month={month}
									>
										{MONTH_NAMES[parseInt(month)]} ({count})
									</a>
								))}
						</div>
					</div>
				);
			})}
		</nav>
	</div>
</aside>

<style>
	.category-sidebar {
		width: 15%;
		min-width: 200px;
		flex-shrink: 0;
		padding: 4rem 4rem 4rem 2rem;
		border-left: 1px solid rgba(0, 0, 0, 0.1);
	}
	@media (max-width: 1023px) {
		.category-sidebar {
			width: 100%;
			padding: 0 6.75rem 2rem 6.75rem;
			border-left: none;
			border-top: 1px solid rgba(0, 0, 0, 0.1);
		}
	}
	.sidebar-title {
		font-family: Inter, ui-sans-serif, system-ui, sans-serif;
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--black));
		margin: 0 0 1rem 0;
	}
	.category-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.category-link {
		font-family: Inter, ui-sans-serif, system-ui, sans-serif;
		font-size: 0.9rem;
		color: hsl(240, 3.8%, 46.1%);
		text-decoration: none;
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
		white-space: nowrap;
	}
	.category-link:hover {
		color: var(--accent);
	}
	.category-link.active {
		color: rgb(var(--black));
		font-weight: 500;
	}
	.category-count {
		font-size: 0.8rem;
		opacity: 0.8;
	}
	.year-month-section {
		margin-top: 2rem;
	}
	.sidebar-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--black));
		margin: 0 0 0.5rem 0;
	}
	.year-month-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.year-group {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.year-link {
		font-weight: 500;
	}
	.months {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding-left: 0.75rem;
	}
	.month-link {
		font-size: 0.85rem;
	}
	.archive-link {
		font-family: Inter, ui-sans-serif, system-ui, sans-serif;
		font-size: 0.9rem;
		color: hsl(240, 3.8%, 46.1%);
		text-decoration: none;
	}
	.archive-link:hover {
		color: var(--accent);
	}
	.archive-link.active {
		color: rgb(var(--black));
		font-weight: 500;
	}
</style>
