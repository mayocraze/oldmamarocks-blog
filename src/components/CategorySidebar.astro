---
import { CATEGORIES } from '../categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
	activeCategory?: string;
	activeYear?: string;
	activeMonth?: string;
}

const { posts, activeCategory, activeYear, activeMonth } = Astro.props;

// Build tag -> category map
const tagToCategory = new Map<string, string>();
CATEGORIES.forEach((cat) => {
	const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
	cat.tags.forEach((tag) => tagToCategory.set(tag.toLowerCase(), slug));
});

// Count posts per category
const categoryCounts = new Map<string, number>();
CATEGORIES.forEach((cat) => {
	const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
	categoryCounts.set(slug, 0);
});

posts.forEach((post) => {
	const postTags = (post.data.tags ?? []).map((t: string) => t.toLowerCase());
	const foundCats = new Set<string>();
	postTags.forEach((tag) => {
		const cat = tagToCategory.get(tag);
		if (cat) foundCats.add(cat);
	});
	foundCats.forEach((cat) => categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1));
});

// Group posts by year and month
const yearMonthCounts = new Map<string, Map<string, number>>();
posts.forEach((post) => {
	const d = post.data.pubDate;
	const year = d.getFullYear().toString();
	const month = (d.getMonth() + 1).toString().padStart(2, '0');
	if (!yearMonthCounts.has(year)) yearMonthCounts.set(year, new Map());
	const months = yearMonthCounts.get(year)!;
	months.set(month, (months.get(month) ?? 0) + 1);
});
const MONTH_NAMES = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const years = Array.from(yearMonthCounts.keys()).sort((a, b) => parseInt(b) - parseInt(a));
---

<aside class="w-full lg:w-[15%] lg:min-w-[200px] flex-shrink-0 pt-8 pb-12 px-4 sm:px-6 lg:pt-16 lg:pb-16 lg:pl-8 lg:pr-16 lg:border-l lg:border-gray-200 border-t border-gray-200 lg:border-t-0">
	<h3 class="text-xs font-semibold uppercase tracking-wider text-gray-900 mb-4">Categories</h3>
	<nav class="flex flex-col gap-2">
		<a
			href="/blog"
			class:list={['category-link flex items-baseline gap-1 text-sm text-gray-500 no-underline hover:text-accent whitespace-nowrap', { 'text-gray-900 font-medium': !activeCategory }]}
		>
			All
		</a>
		{CATEGORIES.map((cat) => {
			const slug = cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
			const count = categoryCounts.get(slug) ?? 0;
			return (
				<a
					href={`/blog?category=${encodeURIComponent(slug)}`}
					class:list={['category-link flex items-baseline gap-1 text-sm text-gray-500 no-underline hover:text-accent whitespace-nowrap', { 'text-gray-900 font-medium': activeCategory === slug }]}
				>
					<span>{cat.name}</span>
					{count > 0 && <span class="text-xs opacity-80">({count})</span>}
				</a>
			);
		})}
	</nav>
	<div class="mt-8">
		<p class="text-[0.75rem] font-semibold uppercase tracking-wider text-gray-900 mb-2">By Year & Month</p>
		<nav class="flex flex-col gap-2">
			{years.map((year) => {
				const months = yearMonthCounts.get(year)!;
				const yearTotal = Array.from(months.values()).reduce((a, b) => a + b, 0);
				return (
					<div class="flex flex-col gap-1">
						<a
							href={`/blog?year=${year}`}
							class:list={['archive-link year-link text-sm text-gray-500 no-underline hover:text-accent font-medium', { 'text-gray-900': activeYear === year && !activeMonth }]}
							data-year={year}
						>
							{year} ({yearTotal})
						</a>
						<div class="flex flex-col gap-0.5 pl-3">
							{Array.from(months.entries())
								.sort(([a], [b]) => parseInt(b) - parseInt(a))
								.map(([month, count]) => (
									<a
										href={`/blog?year=${year}&month=${month}`}
										class:list={['archive-link month-link text-[0.85rem] text-gray-500 no-underline hover:text-accent', { 'text-gray-900 font-medium': activeYear === year && activeMonth === month }]}
										data-year={year}
										data-month={month}
									>
										{MONTH_NAMES[parseInt(month)]} ({count})
									</a>
								))}
						</div>
					</div>
				);
			})}
		</nav>
	</div>
</aside>
