---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="mt-8 mb-12 md:mt-16 md:mb-12 bg-transparent">
	<nav class="flex items-center justify-between gap-4 w-full min-w-0 px-4 sm:px-6 lg:px-[6.75rem] max-w-content mx-auto box-border">
		<h2 class="min-w-0 flex-shrink text-[1.75rem] sm:text-2xl md:text-3xl lg:text-[3.75rem] font-bold tracking-tight leading-tight">
			<a href="/blog" class="no-underline text-inherit">{SITE_TITLE}</a>
		</h2>
		<div class="flex items-center flex-shrink-0 gap-4 md:gap-8">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
